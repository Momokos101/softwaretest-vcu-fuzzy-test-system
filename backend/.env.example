# AutoTestDesign Tool
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# V2 VCU simulator
VCU_SIMULATOR_URL=http://localhost:8001

# LLM provider configuration
# openai_compatible works with OpenAI, DeepSeek, Qwen, Ollama/OpenAI-compatible gateways, etc.
# anthropic uses the native Anthropic Messages API.
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY takes precedence; DASHSCOPE_API_KEY is also supported.
LLM_API_KEY=replace-me
DASHSCOPE_API_KEY=replace-me
LLM_MODEL=qwen3.7-max
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_STREAM=true
LLM_ENABLE_THINKING=true

# Set to none for gateways that reject OpenAI response_format.
LLM_RESPONSE_FORMAT=json_object

# Only used when LLM_PROVIDER=anthropic.
ANTHROPIC_VERSION=2023-06-01
