      {
        "name": "consecutive_wake_sleep_cycles",
        "data_type": "integer",
        "valid_range": {
          "expression": "0-100"
        },
        "unit": "N/A",
        "has_timing": false
      },
      {
        "name": "interval",
        "data_type": "float",
        "valid_range": {
          "expression": "0-10"
        },
        "unit": "s",
        "has_timing": true
      }
    ],
    "conditions": [
      {
        "type": "threshold",
        "description": "consecutive_wake_sleep_cycles >= 3 AND interval < 1s",
        "threshold": 3
      }
    ],
    "expected_actions": [
      {
        "output_field": "vehicle_state",
        "expected_value": 10,
        "operator": "eq"
      },
      {
        "output_field": "result_type",
        "expected_value": "stuck",
        "operator": "eq"
      },
      {
        "output_field": "active_dtcs",
        "expected_value": "DTC_001",
        "operator": "contains"
      }
    ],
    "parse_confidence": 0.95,
    "llm_model": "qwen3.7-max",
    "elapsed_ms": 80585.29720804654,
    "updated_at": "2026-05-24T20:46:48.481832",
    "data_ranges": {
      "consecutive_wake_sleep_cycles": {
        "expression": "0-100"
      },
      "interval": {
        "expression": "0-10"
      }
    },
    "actions": [
      "vehicle_state eq 10",
      "result_type eq stuck",
      "active_dtcs contains DTC_001"
    ]
  },
