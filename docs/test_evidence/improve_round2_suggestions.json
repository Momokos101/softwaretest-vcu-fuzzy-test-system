[
  {
    "requirement_id": "REQ-001",
    "title": "硬线唤醒信号防抖计时器重置验证",
    "reason": "第一轮测试仅验证了连续满足条件的静态边界，未覆盖信号在达到时间阈值前发生短暂跌落导致防抖计时器重置的动态场景。",
    "coverage_item": "信号防抖逻辑与动态跌落重置",
    "test_case": {
      "title": "ST_硬线唤醒_电压跌落导致防抖重置不唤醒",
      "technique": "ST",
      "type": 1,
      "in_data": [
        {
          "name": "voltage_profile",
          "data_type": "string",
          "value": "9.5V_5ms->8.0V_2ms->9.5V_6ms",
          "duration": 13.0,
          "unit": "ms"
        }
      ],
      "expected_results": [
        {
          "name": "vehicle_state",
          "operator": "eq",
          "value": 9,
          "out_type": 1,
          "out_range": 2
        },
        {
          "name": "pdcu_wake_reason",
          "operator": "eq",
          "value": 0,
          "out_type": 1,
          "out_range": 2
        },
        {
          "name": "result_type",
          "operator": "eq",
          "value": "error",
          "out_type": 1,
          "out_range": 2
        }
      ],
      "oracle_reasoning": "电压在5ms时跌落至8.0V(不满足>9.0V)，防抖计时器应清零重置。随后恢复9.5V仅持续6ms，总连续有效时间不足10ms，VCU应维持休眠。"
    }
  },
  {
    "requirement_id": "REQ-002",
    "title": "CAN总线Bus-Off异常状态下的唤醒验证",
    "reason": "第一轮测试覆盖了正常总线状态下的ID边界，但未验证当CAN控制器处于Bus-Off或错误被动状态时，硬件唤醒机制是否依然有效或符合故障安全设计。",
    "coverage_item": "异常总线状态(Bus-Off)下的CAN唤醒",
    "test_case": {
      "title": "EP_CAN总线BusOff状态接收有效唤醒ID",
      "technique": "EP",
      "type": 1,
      "in_data": [
        {
          "name": "can_msg_id",
          "data_type": "integer",
          "value": 1088,
          "duration": 0.0,
          "unit": "N/A"
        },
        {
          "name": "can_bus_status",
          "data_type": "string",
          "value": "Bus-Off",
          "duration": 0.0,
          "unit": "N/A"
        }
      ],
      "expected_results": [
        {
          "name": "vehicle_state",
          "operator": "eq",
          "value": 9,
          "out_type": 1,
          "out_range": 2
        },
        {
          "name": "active_dtcs",
          "operator": "contains",
          "value": "DTC_CAN_BUS_OFF",
          "out_type": 1,
          "out_range": 2
        },
        {
          "name": "result_type",
          "operator": "eq",
          "value": "error",
          "out_type": 1,
          "out_range": 2
        }
      ],
      "oracle_reasoning": "CAN总线处于Bus-Off状态时，控制器无法接收报文，VCU应忽略该唤醒请求，维持休眠状态，并记录总线离线DTC。"
    }
  },
  {
