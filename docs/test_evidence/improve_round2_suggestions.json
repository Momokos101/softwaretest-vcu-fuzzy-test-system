  {
    "requirement_id": "REQ-004",
    "title": "CC与CC2信号并发唤醒优先级与编码验证",
    "reason": "第一轮测试独立验证了CC和CC2的唤醒逻辑，但在实际充电插枪场景中，CC与CC2可能同时满足唤醒阈值，需验证多源并发时的优先级或组合编码逻辑。",
    "coverage_item": "多唤醒源(CC/CC2)并发优先级与编码",
    "test_case": {
      "title": "EP_CC与CC2同时满足唤醒条件",
      "technique": "EP",
      "type": 1,
      "in_data": [
        {
          "name": "cc_voltage",
          "data_type": "float",
          "value": 2.0,
          "duration": 1.0,
          "unit": "V"
        },
        {
          "name": "cc2_voltage",
          "data_type": "float",
          "value": 2.0,
          "duration": 1.0,
          "unit": "V"
        }
      ],
      "expected_results": [
        {
          "name": "vehicle_state",
          "operator": "eq",
          "value": 11,
          "out_type": 1,
          "out_range": 2
        },
        {
          "name": "pdcu_wake_reason",
          "operator": "in",
          "value": [
            4,
            5,
            6
          ],
          "out_type": 1,
          "out_range": 2
        },
        {
          "name": "result_type",
          "operator": "eq",
          "value": "expected",
          "out_type": 1,
          "out_range": 2
        }
      ],
      "oracle_reasoning": "CC(<4.4V)与CC2(<4.4V)同时满足唤醒条件，VCU应成功唤醒。pdcu_wake_reason应根据设计矩阵输出高优先级源编码或两者的组合编码(如按位或)。"
    }
  },
