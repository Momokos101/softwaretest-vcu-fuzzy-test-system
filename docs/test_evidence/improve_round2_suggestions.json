          "value": 1,
          "duration": 120.0,
          "unit": "s"
        },
        {
          "name": "VCUO_bDIAG_AuthComplete_flg",
          "data_type": "boolean",
          "value": 0,
          "duration": 120.0,
          "unit": "s"
        }
