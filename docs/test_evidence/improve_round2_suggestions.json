          "data_type": "boolean",
          "value": 1,
          "duration": 0.0,
          "unit": "N/A"
        },
        {
          "name": "h3",
          "data_type": "boolean",
          "value": 1,
          "duration": 0.0,
          "unit": "N/A"
        },
        {
          "name": "voltage",
          "data_type": "float",
          "value": 12.0,
          "duration": 20.0,
          "unit": "V"
        }
      ],
      "expected_results": [
        {
          "name": "vehicle_state",
          "operator": "eq",
          "value": 11,
          "out_type": 1,
          "out_range": 2
        },
        {
          "name": "pdcu_wake_reason",
          "operator": "eq",
          "value": 1,
          "out_type": 1,
          "out_range": 2
        },
        {
          "name": "result_type",
          "operator": "eq",
          "value": "expected",
          "out_type": 1,
          "out_range": 2
        }
      ],
      "oracle_reasoning": "唤醒事件优先级高于休眠事件。当休眠条件(h1/h2/h3)满足的同时检测到有效硬线唤醒信号，状态机应中止休眠流程，保持或进入唤醒态(state11)。"
    }
  },
